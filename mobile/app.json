{
  "expo": {
    "name": "IvoireStream",
    "slug": "ivoirestream",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "ivoirestream",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0F0F14",
    "splash": {
      "backgroundColor": "#0A120E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ci.ivoirestream.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A120E"
      },
      "package": "ci.ivoirestream.app",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-splash-screen",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
