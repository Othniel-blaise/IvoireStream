{
  "expo": {
    "name": "IvoireStream",
    "slug": "ivoirestream",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "ivoirestream",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0F0F14",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A120E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ci.ivoirestream.app",
      "infoPlist": {
        "NSCameraUsageDescription": "IvoireStream a besoin de la caméra pour diffuser ton live.",
        "NSMicrophoneUsageDescription": "IvoireStream a besoin du micro pour diffuser ton live."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#0A120E"
      },
      "package": "ci.ivoirestream.app",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-splash-screen",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5fc94628-6723-496a-a9f4-16eb0945200d"
      }
    }
  }
}
